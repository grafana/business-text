{
  "name": "business-text",
  "description": "Data-driven text with Markdown and Handlebars support",
  "version": "6.2.3",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "e2e": "playwright test",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "markdownlint": "markdownlint-cli2 AGENTS.md CHANGELOG.md src/CHANGELOG.md README.md",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "start": "docker compose up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --force-recreate --abort-on-container-exit --exit-code-from playwright",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.6.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.32",
    "@swc/helpers": "^0.5.21",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/semver": "^7.7.1",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "copy-webpack-plugin": "^13.0.0",
    "cspell": "^9.8.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.5.0",
    "ts-node": "^10.9.0",
    "typescript": "5.9.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "12.4.2",
    "@grafana/i18n": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/scenes": "^7.4.2",
    "@grafana/schema": "12.4.2",
    "@grafana/ui": "12.4.2",
    "@hello-pangea/dnd": "^18.0.1",
    "dayjs": "^1.11.20",
    "handlebars": "^4.7.9",
    "helper-date": "^1.0.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "semver": "^7.7.4",
    "tslib": "^2.8.1",
    "uuid": "^13.0.1"
  },
  "packageManager": "npm@11.12.1"
}
